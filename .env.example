# API Keys - replace with your real values
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=rag-assistant

CLAUDE_API_KEY=your_claude_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Database
POSTGRES_DB=rag_assistant
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_db_password
DATABASE_URL=postgresql://your_db_user:your_strong_db_password@localhost:5432/rag_assistant
REDIS_URL=redis://localhost:6379

# Authentication - generate with: openssl rand -hex 64
JWT_SECRET=generate_a_strong_random_secret_here
BCRYPT_ROUNDS=12

# Internal service-to-service API key - generate with: openssl rand -hex 32
PYTHON_SERVICE_API_KEY=generate_a_strong_random_key_here

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=choose_a_strong_password
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Application
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000

# Monitoring
LOG_LEVEL=info
ENABLE_METRICS=true

# Document Processing
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=200
EMBEDDING_MODEL=text-embedding-ada-002

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
